// Version.hpp is generated from Version.hpp.in,
// it contains build info and version info strings injected into the header file during the build

#pragma once

#include <array>

namespace cmf {

// structure to define a build parameter - name and value
struct BuildInfo
{
    const char* name;
    const char* value;

    template <typename Fn>
    friend void visit(BuildInfo& obj, const Fn& fn)
    {
        fn(obj.name, obj.value);
    }
};

// specific build parameters listed below
inline constexpr std::array buildInfo = std::to_array<BuildInfo>({
    {"BUILD_NODE",   "${BUILD_NODE}"},
    {"BUILD_SYSTEM", "${CMAKE_SYSTEM}"},
    {"BUILD_TYPE",   "${CMAKE_BUILD_TYPE}"},
    {"C",            "${CMAKE_C_COMPILER} (${CMAKE_C_COMPILER_ID} ${CMAKE_C_COMPILER_VERSION})"},
    {"CXX",          "${CMAKE_CXX_COMPILER} (${CMAKE_CXX_COMPILER_ID} ${CMAKE_CXX_COMPILER_VERSION})"},
    {"BUILD_TESTS",  "${BUILD_TESTS}"}
});

// structure to define a version
struct VersionInfo
{
    const char* component;
    const char* version;
    const char* hash;
    const char* date;
    const char* branch;
    const char* commitMsg;

    template <typename Fn>
    friend void visit(VersionInfo& obj, const Fn& fn)
    {
        fn("component", obj.component);
        fn("version", obj.version);
        fn("hash", obj.hash);
        fn("date", obj.date);
        fn("branch", obj.branch);
        fn("commitMsg", obj.commitMsg);
    }
};

// list of components and their versions is defined by VERSION_INFO variable
inline constexpr std::array versionInfo = std::to_array<VersionInfo>({
${VERSION_INFO}
});

}
